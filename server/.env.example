# Copia este archivo como ".env" en la carpeta /server
# Ruta del archivo de base de datos SQLite (no necesitas cambiarla)
DATABASE_URL="file:./dev.db"

# Clave secreta para firmar los tokens JWT (cámbiala por una propia)
JWT_SECRET="cambia-esta-clave-secreta-sena-lms"

# Puerto del servidor backend
PORT=4000

# ----- Solo para el DESPLIEGUE GRATIS en internet (Render + Supabase) -----
# En tu computador puedes dejar estas variables vacías o borrarlas.

# Código que se pedirá para registrar nuevos instructores (invéntalo tú)
# CODIGO_REGISTRO="SENA-2026"

# Datos del proyecto de Supabase (Storage para los archivos de materiales)
# SUPABASE_URL="https://tu-proyecto.supabase.co"
# SUPABASE_SERVICE_KEY="tu-service-role-key"
# SUPABASE_BUCKET="materiales"
