// Esquema de la base de datos del LMS SENA
// Base de datos: SQLite (archivo local, sin configuración externa)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Usuario: instructor o aprendiz
model Usuario {
  id           Int         @id @default(autoincrement())
  nombre       String
  correo       String      @unique
  passwordHash String
  rol          String // "instructor" | "aprendiz"
  creadoEn     DateTime    @default(now())
  cursos       Curso[]     @relation("CursosDelInstructor")
  matriculas   Matricula[]
  evidencias   Evidencia[]
}

// Curso: máximo 10 en total (se valida en el backend)
model Curso {
  id           Int           @id @default(autoincrement())
  nombre       String
  descripcion  String?
  ficha        String?
  instructorId Int
  creadoEn     DateTime      @default(now())
  instructor   Usuario       @relation("CursosDelInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  competencias Competencia[]
  matriculas   Matricula[]
}

// Matrícula: máximo 30 aprendices por curso (se valida en el backend)
model Matricula {
  cursoId    Int
  aprendizId Int
  creadoEn   DateTime @default(now())
  curso      Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  aprendiz   Usuario  @relation(fields: [aprendizId], references: [id], onDelete: Cascade)

  @@id([cursoId, aprendizId])
}

// Competencia de un curso (ej. 220501092 Establecimiento de requisitos...)
model Competencia {
  id          Int         @id @default(autoincrement())
  cursoId     Int
  codigo      String
  nombre      String
  orden       Int
  curso       Curso       @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  secciones   Seccion[]
  actividades Actividad[]
}

// Las 6 secciones fijas de cada competencia
model Seccion {
  id            Int         @id @default(autoincrement())
  competenciaId Int
  tipo          String // guias | presentaciones | material_apoyo | instrumentos | planes_sesion | evidencias
  competencia   Competencia @relation(fields: [competenciaId], references: [id], onDelete: Cascade)
  materiales    Material[]

  @@unique([competenciaId, tipo])
}

// Material subido por el instructor (archivo o enlace) en las secciones 1-5
model Material {
  id          Int      @id @default(autoincrement())
  seccionId   Int
  titulo      String
  tipo        String // "archivo" | "enlace"
  archivoPath String?
  url         String?
  creadoEn    DateTime @default(now())
  seccion     Seccion  @relation(fields: [seccionId], references: [id], onDelete: Cascade)
}

// Actividad de aprendizaje (AA_01...AA_05) definida por el instructor
model Actividad {
  id            Int         @id @default(autoincrement())
  competenciaId Int
  codigo        String
  titulo        String
  descripcion   String?
  competencia   Competencia @relation(fields: [competenciaId], references: [id], onDelete: Cascade)
  evidencias    Evidencia[]
}

// Evidencia del aprendiz: SOLO una URL (no se suben archivos)
model Evidencia {
  id                Int       @id @default(autoincrement())
  actividadId       Int
  aprendizId        Int
  titulo            String
  url               String
  comentario        String?
  creadoEn          DateTime  @default(now())
  estado            String    @default("pendiente") // "pendiente" | "revisado"
  nota              Float?
  retroalimentacion String?
  actividad         Actividad @relation(fields: [actividadId], references: [id], onDelete: Cascade)
  aprendiz          Usuario   @relation(fields: [aprendizId], references: [id], onDelete: Cascade)

  // Un aprendiz entrega una sola evidencia por actividad (puede editarla)
  @@unique([actividadId, aprendizId])
}
